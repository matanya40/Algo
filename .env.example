# =============================================================================
# Local: copy this file to `.env.local` (gitignored). Use your Supabase *dev* project.
#
# Production: Vercel → Project → Settings → Environment Variables → Production.
#   Use a separate Supabase *prod* project (same schema.sql), different URL + anon key.
#
# After first deploy: Supabase (prod) → Auth → URL configuration — set Site URL and
# Redirect URLs to https://<your-app>.vercel.app (and /auth/callback). Do the same in
# Google Cloud OAuth authorized redirect URIs for both Supabase projects if you use Google.
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-dev-project.supabase.co
# Anon JWT (eyJ…) from Project Settings → API. Not the service_role key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: Project Settings → API → service_role (secret). Used to resolve invitee email →
# user id when sharing strategies. Never expose to the browser or client bundles.

# Optional — for npm run db:apply / db:reset / db:rebuild (align DB with supabase/*.sql).
# Project Settings → Database → Connection string → URI (include password). Dev project only.
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-....pooler.supabase.com:6543/postgres

# Optional: canonical public URL (no trailing slash). On Vercel set this to your deployment URL
# so OAuth always returns to prod (e.g. https://your-app.vercel.app) instead of localhost.
# Must match Supabase Auth → URL configuration → Site URL + Redirect URLs allowlist.
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Optional: label in the top bar. If unset: local shows "development"; on Vercel uses VERCEL_ENV.
# NEXT_PUBLIC_APP_ENV=development

# Optional: OAuth trace logs (server only). Set to 1, then watch terminal (local) or Vercel → Logs.
# Does not log full auth codes. Remove or unset after debugging.
# AUTH_DEBUG_LOGS=1

# Tradovate (server-only): encrypt password/sec with AES-256-GCM. Use 32-byte key as base64, or 64 hex chars,
# or a long passphrase (derived with scrypt in lib/crypto/aes-gcm.ts).
# TRADOVATE_ENCRYPTION_KEY=
# TRADOVATE_DEMO_BASE_URL=https://demo.tradovateapi.com
# TRADOVATE_LIVE_BASE_URL=https://live.tradovateapi.com
